{
  "manifest_version": 3,
  "name": "NewTabFolders",
  "short_name": "NTF",
  "version": "1.0.0",
  "description": "Organize your bookmarks with beautiful folders. Free plan available. PRO: unlimited folders, themes, cloud sync.",
  "permissions": [
    "storage",
    "tabs",
    "sessions"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png"
    },
    "default_title": "NewTabFolders"
  }
}
